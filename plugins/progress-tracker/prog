#!/bin/bash
# Progress Tracker CLI entry point
# Automatically locates the plugin root and runs the appropriate script
#
# Usage:
#   prog <progress_manager_command> [args...]
#   prog memory <project_memory_command> [args...]
#
# This script can be called from any directory and will correctly
# locate the scripts relative to its own location.

set -e

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Check first argument to determine which script to run
if [ "$1" = "memory" ]; then
    # Shift 'memory' argument and run project_memory.py
    shift
    python3 "$SCRIPT_DIR/hooks/scripts/project_memory.py" "$@"
else
    # Default to progress_manager.py
    python3 "$SCRIPT_DIR/hooks/scripts/progress_manager.py" "$@"
fi

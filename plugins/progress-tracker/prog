#!/bin/bash
# Progress Tracker CLI entry point
# Automatically locates the plugin root and runs the appropriate script
#
# Usage:
#   prog <progress_manager_command> [args...]
#   prog memory <project_memory_command> [args...]
#
# This script can be called from any directory and will correctly
# locate the scripts relative to its own location.

set -e

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Normalize global args so --project-root can appear anywhere.
PROJECT_ARGS=()
OTHER_ARGS=()

while [ "$#" -gt 0 ]; do
    case "$1" in
        --project-root)
            PROJECT_ARGS+=("$1")
            shift
            if [ "$#" -eq 0 ]; then
                echo "Error: --project-root requires a value" >&2
                exit 1
            fi
            PROJECT_ARGS+=("$1")
            ;;
        --project-root=*)
            PROJECT_ARGS+=("$1")
            ;;
        *)
            OTHER_ARGS+=("$1")
            ;;
    esac
    shift
done

# Route to project_memory.py when first non-global arg is `memory`.
if [ "${#OTHER_ARGS[@]}" -gt 0 ] && [ "${OTHER_ARGS[0]}" = "memory" ]; then
    python3 "$SCRIPT_DIR/hooks/scripts/project_memory.py" \
        "${PROJECT_ARGS[@]}" \
        "${OTHER_ARGS[@]:1}"
else
    python3 "$SCRIPT_DIR/hooks/scripts/progress_manager.py" \
        "${PROJECT_ARGS[@]}" \
        "${OTHER_ARGS[@]}"
fi

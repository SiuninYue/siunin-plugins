{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/run-hook.sh check",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": "hooks/run-hook.sh sync-runtime-context --source session_start --quiet",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "hooks/run-hook.sh git-sync-check",
            "timeout": 10000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "hooks/run-hook.sh auto-checkpoint",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
